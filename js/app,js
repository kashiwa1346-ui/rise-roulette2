// アプリ内一元管理データ（初期デフォルト）
const defaultData = {
    players: [
        { id: 1, name: "プレイヤー1", avatar: "" },
        { id: 2, name: "プレイヤー2", avatar: "" },
        { id: 3, name: "プレイヤー3", avatar: "" }
    ],
    stopOrder: [1, 2, 3],
    weapons: [
        { name: "大剣", icon: "" },
        { name: "太刀", icon: "" },
        { name: "片手剣", icon: "" },
        { name: "双剣", icon: "" }
    ],
    restrictions: [
        { name: "アイテム使用禁止", icon: "" },
        { name: "防具装備なし", icon: "" },
        { name: "ノーダメージクリア", icon: "" }
    ]
};

let appData = JSON.parse(localStorage.getItem("roulette_config")) || defaultData;
let rouletteIntervals = {};

// 主要DOM要素
const startBtn = document.getElementById("start-btn");
const stopBtn = document.getElementById("stop-btn");
const settingsModal = document.getElementById("settings-modal");

// 汎用：画像ファイルをBase64文字列に変換する処理
function fileToBase64(file) {
    return new Promise((resolve) => {
        if (!file) return resolve(null);
        const reader = new FileReader();
        reader.onload = (e) => resolve(e.target.result);
        reader.readAsDataURL(file);
    });
}

// 画面同期初期化
function initDisplay() {
    appData.players.forEach(p => {
        // メイン画面の入力フォームと画像へ同期
        const nameInput = document.getElementById(`p${p.id}-name-input`);
        const avatarImg = document.getElementById(`p${p.id}-avatar`);
        
        if (nameInput) nameInput.value = p.name;
        if (avatarImg) {
            avatarImg.src = p.avatar || "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='100' height='100'><rect width='100' height='100' fill='%23252131'/><text x='50%' y='55%' font-family='sans-serif' font-size='14' fill='%2300f0ff' text-anchor='middle'>NO IMAGE</text></svg>";
        }
    });
}

// メイン画面からのプレイヤーデータ変更イベント設定
function setupDirectEditListeners() {
    appData.players.forEach(p => {
        // 名前変更イベント
        const nameInput = document.getElementById(`p${p.id}-name-input`);
        nameInput.addEventListener("change", () => {
            p.name = nameInput.value;
            saveToLocalStorage();
        });

        // 画像変更イベント
        const avatarInput = document.getElementById(`p${p.id}-avatar-input`);
        avatarInput.addEventListener("change", async (e) => {
            const file = e.target.files[0];
            if (file) {
                const base64Str = await fileToBase64(file);
                p.avatar = base64Str;
                document.getElementById(`p${p.id}-avatar`).src = base64Str;
                saveToLocalStorage();
            }
        });
    });
}

function saveToLocalStorage() {
    localStorage.setItem("roulette_config", JSON.stringify(appData));
}

// ルーレットアイテムレンダリング
function renderRouletteItem(elementId, item, placeholder) {
    const el = document.getElementById(elementId);
    if (!item) {
        el.innerHTML = placeholder;
        return;
    }
    const imgTag = item.icon ? `<img src="${item.icon}">` : "";
    el.innerHTML = `${imgTag}<span>${item.name}</span>`;
}

// ルーレット開始処理
startBtn.addEventListener("click", () => {
    startBtn.disabled = true;
    stopBtn.disabled = true;

    appData.players.forEach(p => {
        document.getElementById(`player-card-${p.id}`).classList.add("active-roulette");
        
        // 武器ルーレット駆動
        rouletteIntervals[`w_${p.id}`] = setInterval(() => {
            const item = appData.weapons[Math.floor(Math.random() * appData.weapons.length)];
            renderRouletteItem(`p${p.id}-weapon`, item, "WEAPON");
        }, 50);

        // 縛りルーレット駆動
        rouletteIntervals[`r_${p.id}`] = setInterval(() => {
            const item = appData.restrictions[Math.floor(Math.random() * appData.restrictions.length)];
            renderRouletteItem(`p${p.id}-restriction`, item, "LIMIT");
        }, 50);

        document.getElementById(`p${p.id}-weapon`).classList.add("blur-anime");
        document.getElementById(`p${p.id}-restriction`).classList.add("blur-anime");
    });

    // 0.5秒間は強制アニメーション（ストップ不可）
    setTimeout(() => {
        stopBtn.disabled = false;
    }, 500);
});

// ルーレット停止処理（時間差順次停止）
stopBtn.addEventListener("click", () => {
    stopBtn.disabled = true;
    let delay = 0;

    appData.stopOrder.forEach((playerId, index) => {
        // 武器ルーレット停止タイマー
        setTimeout(() => {
            clearInterval(rouletteIntervals[`w_${playerId}`]);
            document.getElementById(`p${playerId}-weapon`).classList.remove("blur-anime");
        }, delay += 500);

        // 縛りルーレット停止タイマー
        setTimeout(() => {
            clearInterval(rouletteIntervals[`r_${playerId}`]);
            document.getElementById(`p${playerId}-restriction`).classList.remove("blur-anime");
            document.getElementById(`player-card-${playerId}`).classList.remove("active-roulette");
            
            // 全てのルーレット（最後のプレイヤーの縛り）が完全に止まったか判定
            if (index === appData.stopOrder.length - 1) {
                startBtn.disabled = false; // ボタンロック解除
            }
        }, delay += 500);
    });
});

// --- 設定管理（モーダル関連ロジック） ---
document.getElementById("open-settings-btn").addEventListener("click", () => {
    buildSettingsForm();
    settingsModal.showModal();
});

document.getElementById("save-settings-btn").addEventListener("click", async () => {
    await saveSettingsForm();
    settingsModal.close();
    initDisplay();
});

function buildSettingsForm() {
    // 停止順序セレクト同期
    document.getElementById("stop-order-select").value = appData.stopOrder.join(",");
    // リスト領域構築
    buildListRows("weapon", appData.weapons);
    buildListRows("restriction", appData.restrictions);
}

function buildListRows(type, list) {
    const container = document.getElementById(`${type}-list-edit`);
    container.innerHTML = "";
    list.forEach((item) => {
        container.innerHTML += `
            <div class="list-row ${type}-row">
                <input type="text" class="${type}-name" value="${item.name}">
                <input type="file" class="${type}-icon" accept="image/*">
                <input type="hidden" class="${type}-old-img" value="${item.icon}">
                <button type="button" class="del-btn" onclick="this.parentElement.remove()">削除</button>
            </div>
        `;
    });
}

function addListRow(type) {
    const container = document.getElementById(`${type}-list-edit`);
    container.insertAdjacentHTML("beforeend", `
        <div class="list-row ${type}-row">
            <input type="text" class="${type}-name" value="" placeholder="新規項目名">
            <input type="file" class="${type}-icon" accept="image/*">
            <input type="hidden" class="${type}-old-img" value="">
            <button type="button" class="del-btn" onclick="this.parentElement.remove()">削除</button>
        </div>
    `);
}

async function saveSettingsForm() {
    // 停止順序配列取得
    appData.stopOrder = document.getElementById("stop-order-select").value.split(",").map(Number);

    // 武器タイプリスト同期
    appData.weapons = [];
    const wRows = document.querySelectorAll(".weapon-row");
    for (let row of wRows) {
        const name = row.querySelector(".weapon-name").value;
        const file = row.querySelector(".weapon-icon").files[0];
        const oldImg = row.querySelector(".weapon-old-img").value;
        const icon = file ? await fileToBase64(file) : oldImg;
        if (name) appData.weapons.push({ name, icon });
    }

    // 縛り内容リスト同期
    appData.restrictions = [];
    const rRows = document.querySelectorAll(".restriction-row");
    for (let row of rRows) {
        const name = row.querySelector(".restriction-name").value;
        const file = row.querySelector(".restriction-icon").files[0];
        const oldImg = row.querySelector(".restriction-old-img").value;
        const icon = file ? await fileToBase64(file) : oldImg;
        if (name) appData.restrictions.push({ name, icon });
    }

    saveToLocalStorage();
}

// 初回ロード実行
initDisplay();
setupDirectEditListeners();